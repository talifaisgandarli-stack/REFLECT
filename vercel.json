{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "crons": [
    { "path": "/api/cron/forecast", "schedule": "0 3 * * *" },
    { "path": "/api/cron/recurring-expenses", "schedule": "0 2 * * *" },
    { "path": "/api/cron/cmo", "schedule": "0 7 * * 1" },
    { "path": "/api/cron/notify-fanout", "schedule": "0 8 * * *" },
    { "path": "/api/cron/deadline-reminders", "schedule": "0 5 * * *" },
    { "path": "/api/cron/finance-alerts", "schedule": "0 6 * * *" }
  ]
}
