{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "crons": [
    { "path": "/api/cron/forecast", "schedule": "0 3 * * *" },
    { "path": "/api/cron/cmo", "schedule": "0 7 * * 1" },
    { "path": "/api/cron/recurring", "schedule": "0 2 * * *" },
    { "path": "/api/cron/okr-nudge", "schedule": "0 8 * * 1" },
    { "path": "/api/cron/notify-dispatch", "schedule": "*/5 * * * *" }
  ]
}
