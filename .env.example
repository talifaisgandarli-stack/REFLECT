# Supabase (frontend — anon key only, safe to expose)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only (Vercel /api/* edge functions — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=

# Voyage AI — used for RAG embeddings (voyage-3.5-lite, 1024-dim multilingual).
# Free trial: 200M tokens (practically unlimited for typical use).
# Anthropic-recommended provider. Get key: https://dash.voyageai.com
# RAG is skipped gracefully if absent, but knowledge_base search won't work.
VOYAGE_API_KEY=

# App public URL — used in invitation emails (e.g. https://reflect.yourdomain.com)
PUBLIC_APP_URL=

# Cron secret — used to trigger crons manually via ?key=<secret>
# Vercel cron jobs authenticate automatically via x-vercel-cron header.
CRON_SECRET=

# Telegram webhook — used to validate incoming updates from Telegram
TELEGRAM_WEBHOOK_SECRET=

# Email sender (optional — defaults to "Reflect <noreply@reflect.studio>")
# RESEND_FROM=Reflect <noreply@yourdomain.com>
